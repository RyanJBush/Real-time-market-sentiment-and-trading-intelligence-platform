APP_NAME=Atlas API
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173"]

# Local / dev: set DATABASE_URL to SQLite for zero-config startup.
# For full Docker Compose, leave DATABASE_URL empty and POSTGRES_* will be used.
DATABASE_URL=sqlite:///./atlas.db
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas

# NLP_PROVIDER: heuristic (deterministic, no model download) | transformers (FinBERT) | auto
NLP_PROVIDER=heuristic
NLP_MODEL_NAME=ProsusAI/finbert

# Dev convenience: auto-create SQLAlchemy tables on startup
AUTO_CREATE_TABLES=true
